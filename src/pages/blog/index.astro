---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection } from "astro:content";
import BaseHead from "@astro/base/BaseHead.astro";
import Footer from "@astro/footer/Footer.astro";
import Header from "@astro/header/Header.astro";
import { featureFlags } from "@config/featureFlag/featureFlag.json";
import authorConfig from "@config/siteConfig/info.json";

export const prerender = true;

const postsPerPage = 9;

const allPosts = (await getCollection("blog"))
	.filter(
		(post: CollectionEntry<"blog">) => !post.data.draft && !post.data.archived,
	)
	.sort(
		(a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const currentPage = 1;

const posts: CollectionEntry<"blog">[] = allPosts.slice(0, postsPerPage);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const remainingPosts = featuredPost
	? posts.filter((post) => post !== featuredPost)
	: [];
const quickReads = remainingPosts.slice(0, 3);
const latePosts = remainingPosts.slice(3);

const tagCounts = new Map();
for (const post of allPosts) {
	for (const tag of post.data.tags || []) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}

const formatDate = (date: Date) =>
	new Date(date).toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
		year: "numeric",
	});

const showTags = featureFlags.showTags;
const showSearch = featureFlags.showSearch;

try {
	if (!featureFlags.showBlog) {
		return Astro.redirect("/access-denied");
	}
} catch (_error) {
	return Astro.redirect("/404");
}
---

<html lang="en">
  <head>
    <BaseHead
      title={`Articles | ${authorConfig.SiteName}`}
      description={`Browse all articles on ${authorConfig.SiteName} — a premium editorial experience.`}
    />

    <style is:inline>
      html {
        background-color: #1a1b26 !important;
      }
      body {
        background-color: #1a1b26 !important;
      }
      #__astro {
        background-color: #1a1b26 !important;
      }
    </style>

    <style>
      html {
        background-color: #1a1b26 !important;
      }
      body {
        background-color: #1a1b26 !important;
        transition: none !important;
      }
    </style>

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Blog",
        name: `${authorConfig.SiteName} Blog`,
        description: `Browse all articles on ${authorConfig.SiteName} — a premium editorial experience.`,
        url: "https://rafay99.com/blog",
        publisher: {
          "@type": "Organization",
          name: authorConfig.SiteName,
          logo: {
            "@type": "ImageObject",
            url: "https://rafay99.com/favicon.webp",
          },
        },
        blogPost: posts.map(
          (post: CollectionEntry<"blog">, _index: number) => ({
            "@type": "BlogPosting",
            headline: post.data.title,
            description: post.data.description,
            author: {
              "@type": "Person",
              name: post.data.authorName,
            },
            datePublished: post.data.pubDate.toISOString(),
            url: `https://rafay99.com/blog/${post.id}`,
            keywords: post.data.tags?.join(", ") || "blog, technology",
          }),
        ),
      })}
    />
  </head>

  <body class="flex min-h-screen flex-col bg-[#1a1b26] text-[#a9b1d6]">
    <Header />

    <main class="editorial-shell mx-auto w-full max-w-6xl flex-1 px-5 pb-24 pt-10 sm:px-6">

      <!-- ═══ Masthead Bar ═══ -->
      <div class="masthead fade-up">
        <h1 class="masthead-title">STUDIO JOURNAL</h1>
        <div class="masthead-stats">
          <span>{totalPosts} Articles</span>
          <span class="masthead-dot">&middot;</span>
          <span>{tagCounts.size} Topics</span>
          <span class="masthead-dot">&middot;</span>
          <span>Est. 2024</span>
        </div>
        <div class="masthead-links">
          <a href="/blog/archive" class="masthead-link">Archive</a>
          {featureFlags.showSeries && <a href="/blog/series" class="masthead-link">Series</a>}
          {showSearch && <a href="/search" class="masthead-link">Search</a>}
          {showTags && <a href="/tag" class="masthead-link">Tags</a>}
        </div>
      </div>

      {posts.length === 0 && (
        <div class="empty-state">
          <p>No published articles yet. Check back soon.</p>
        </div>
      )}

      <!-- ═══ Hero Feature ═══ -->
      {featuredPost && (
        <section class="hero-feature fade-up delay-1">
          <a href={`/blog/${featuredPost.id}`} class="hero-feature-inner group">
            <div class="hero-image-side">
              {featuredPost.data.heroImage ? (
                <Image
                  src={featuredPost.data.heroImage}
                  alt={featuredPost.data.title}
                  width={800}
                  height={500}
                  loading="eager"
                  decoding="async"
                  class="hero-img"
                />
              ) : (
                <div class="hero-fallback" aria-hidden="true" />
              )}
            </div>
            <div class="hero-accent-line" aria-hidden="true"></div>
            <div class="hero-text-side">
              <span class="hero-label">FEATURED</span>
              <span class="hero-date">{formatDate(featuredPost.data.pubDate)}</span>
              <h2 class="hero-title">{featuredPost.data.title}</h2>
              <p class="hero-excerpt line-clamp-3">
                {featuredPost.data.excerpt || featuredPost.data.description}
              </p>
              <span class="hero-cta">
                Read story <span class="cta-arrow">&rarr;</span>
              </span>
            </div>
          </a>
        </section>
      )}

      <!-- ═══ Three-Column Quick Reads ═══ -->
      {quickReads.length > 0 && (
        <section class="quick-reads fade-up delay-2">
          {quickReads.map((post, index) => (
            <a
              href={`/blog/${post.id}`}
              class:list={["quick-card group", `fade-up delay-${index + 2}`]}
            >
              <div class="quick-card-image">
                {post.data.heroImage ? (
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width={400}
                    height={225}
                    loading="lazy"
                    decoding="async"
                    class="quick-img"
                  />
                ) : (
                  <div class="quick-fallback" aria-hidden="true" />
                )}
              </div>
              <div class="quick-card-body">
                <span class="quick-date">{formatDate(post.data.pubDate)}</span>
                <h3 class="quick-title line-clamp-2">{post.data.title}</h3>
                <p class="quick-excerpt line-clamp-2">
                  {post.data.excerpt || post.data.description}
                </p>
              </div>
            </a>
          ))}
        </section>
      )}

      <!-- ═══ More Stories — Magazine Spread ═══ -->
      {latePosts.length > 0 && (
        <section class="more-stories">
          <div class="more-header fade-up delay-3">
            <h2 class="more-heading">More from the Journal</h2>
            <div class="more-heading-line" aria-hidden="true"></div>
          </div>

          {/* ── Spotlight: First post gets the hero treatment ── */}
          {latePosts[0] && (
            <a href={`/blog/${latePosts[0].id}`} class="spotlight group fade-up delay-3">
              <div class="spotlight-image">
                {latePosts[0].data.heroImage ? (
                  <Image
                    src={latePosts[0].data.heroImage}
                    alt={latePosts[0].data.title}
                    width={700}
                    height={400}
                    loading="lazy"
                    decoding="async"
                    class="spotlight-img"
                  />
                ) : (
                  <div class="spotlight-fallback" aria-hidden="true" />
                )}
                <div class="spotlight-number" aria-hidden="true">01</div>
              </div>
              <div class="spotlight-body">
                <div class="spotlight-meta">
                  {latePosts[0].data.tags?.[0] && (
                    <span class="spotlight-tag">{latePosts[0].data.tags[0]}</span>
                  )}
                  <span class="spotlight-date">{formatDate(latePosts[0].data.pubDate)}</span>
                  {latePosts[0].data.readTime && (
                    <span class="spotlight-date">&middot; {latePosts[0].data.readTime}</span>
                  )}
                </div>
                <h3 class="spotlight-title">{latePosts[0].data.title}</h3>
                <p class="spotlight-excerpt line-clamp-3">
                  {latePosts[0].data.excerpt || latePosts[0].data.description}
                </p>
                <span class="spotlight-cta">
                  Continue reading <span class="cta-arrow">&rarr;</span>
                </span>
              </div>
            </a>
          )}

          {/* ── Visual Grid: Remaining posts as rich visual cards ── */}
          {latePosts.length > 1 && (
            <div class="story-grid">
              {latePosts.slice(1).map((post, index) => (
                <a
                  href={`/blog/${post.id}`}
                  class:list={["story-card group", `fade-up delay-${Math.min(index + 4, 6)}`]}
                >
                  <div class="story-card-visual">
                    {post.data.heroImage ? (
                      <Image
                        src={post.data.heroImage}
                        alt={post.data.title}
                        width={480}
                        height={300}
                        loading="lazy"
                        decoding="async"
                        class="story-card-img"
                      />
                    ) : (
                      <div class="story-card-fallback" aria-hidden="true" />
                    )}
                    <div class="story-card-overlay" aria-hidden="true"></div>
                    <span class="story-card-number" aria-hidden="true">
                      {String(index + 2).padStart(2, "0")}
                    </span>
                    {post.data.tags?.[0] && (
                      <span class="story-card-badge">{post.data.tags[0]}</span>
                    )}
                  </div>
                  <div class="story-card-content">
                    <span class="story-card-date">
                      {formatDate(post.data.pubDate)}
                      {post.data.readTime && <> &middot; {post.data.readTime}</>}
                    </span>
                    <h3 class="story-card-title line-clamp-2">{post.data.title}</h3>
                    <p class="story-card-excerpt line-clamp-2">
                      {post.data.excerpt || post.data.description}
                    </p>
                    <span class="story-card-read">
                      Read <span class="cta-arrow">&rarr;</span>
                    </span>
                  </div>
                </a>
              ))}
            </div>
          )}
        </section>
      )}

      <!-- ═══ Pagination ═══ -->
      {totalPages > 1 && (
        <nav class="pagination fade-up" aria-label="Pagination">
          <a
            href={currentPage > 1 ? `/blog/page/${currentPage - 1}` : undefined}
            class:list={[
              "pagination-link",
              currentPage > 1 ? "pagination-active" : "pagination-disabled",
            ]}
            aria-disabled={currentPage > 1 ? undefined : "true"}
            tabindex={currentPage > 1 ? undefined : "-1"}
          >
            &larr; Previous
          </a>
          <div class="pagination-indicator">
            <span class="pagination-current">{currentPage}</span>
            <span class="pagination-sep">/</span>
            <span class="pagination-total">{totalPages}</span>
          </div>
          <a
            href={currentPage < totalPages ? `/blog/page/${currentPage + 1}` : undefined}
            class:list={[
              "pagination-link",
              currentPage < totalPages ? "pagination-active" : "pagination-disabled",
            ]}
            aria-disabled={currentPage < totalPages ? undefined : "true"}
            tabindex={currentPage < totalPages ? undefined : "-1"}
          >
            Next &rarr;
          </a>
        </nav>
      )}

    </main>

    <Footer />

    <style>
      /* ═══════════════════════════════════════════════════════
         V1 — Editorial Magazine (Bloomberg / NYT Digital)
         ═══════════════════════════════════════════════════════ */

      .editorial-shell {
        position: relative;
        isolation: isolate;
      }

      /* ─── Masthead ─── */
      .masthead {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid rgba(86, 95, 137, 0.35);
        margin-bottom: 2.5rem;
      }

      .masthead-title {
        font-size: clamp(1.4rem, 2.5vw, 2rem);
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #f8f8ff;
        line-height: 1;
      }

      .masthead-stats {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: #565f89;
        letter-spacing: 0.03em;
      }

      .masthead-dot {
        color: rgba(86, 95, 137, 0.5);
      }

      .masthead-links {
        margin-left: auto;
        display: flex;
        gap: 1rem;
        font-size: 0.82rem;
      }

      .masthead-link {
        color: #7aa2f7;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s ease;
      }

      .masthead-link:hover {
        color: #bb9af7;
      }

      /* ─── Hero Feature ─── */
      .hero-feature {
        margin-bottom: 2.5rem;
      }

      .hero-feature-inner {
        display: grid;
        grid-template-columns: 3fr auto 2fr;
        gap: 0;
        border-radius: 16px;
        border: 1px solid rgba(86, 95, 137, 0.3);
        background: rgba(36, 40, 59, 0.6);
        overflow: hidden;
        transition:
          border-color 0.3s ease,
          box-shadow 0.3s ease,
          transform 0.3s ease;
      }

      .hero-feature-inner:hover {
        border-color: rgba(122, 162, 247, 0.55);
        box-shadow: 0 20px 50px rgba(10, 12, 22, 0.5);
        transform: translateY(-3px);
      }

      /* ── Shimmer skeleton for image containers ── */
      .hero-image-side,
      .quick-card-image,
      .spotlight-image,
      .story-card-visual {
        background: rgba(36, 40, 59, 0.7);
        background-image: linear-gradient(
          90deg,
          rgba(36, 40, 59, 0.7) 0%,
          rgba(65, 72, 104, 0.3) 50%,
          rgba(36, 40, 59, 0.7) 100%
        );
        background-size: 200% 100%;
        animation: shimmer 1.8s ease-in-out infinite;
      }

      @keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }

      /* ── Fade-in for loaded images ── */
      .hero-img,
      .quick-img,
      .spotlight-img,
      .story-card-img {
        opacity: 0;
        transition: opacity 0.4s ease, transform 0.5s ease;
      }

      .hero-img.loaded,
      .quick-img.loaded,
      .spotlight-img.loaded,
      .story-card-img.loaded {
        opacity: 1;
      }

      .hero-image-side {
        position: relative;
        overflow: hidden;
        min-height: 320px;
      }

      .hero-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .hero-feature-inner:hover .hero-img {
        transform: scale(1.04);
      }

      .hero-fallback {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(36, 40, 59, 0.9), rgba(122, 162, 247, 0.25));
      }

      .hero-accent-line {
        width: 3px;
        background: linear-gradient(180deg, #7aa2f7, #bb9af7);
        flex-shrink: 0;
      }

      .hero-text-side {
        padding: 2rem 2.2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.6rem;
      }

      .hero-label {
        font-size: 0.65rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        font-weight: 700;
        color: #bb9af7;
      }

      .hero-date {
        font-size: 0.78rem;
        color: #565f89;
      }

      .hero-title {
        font-size: clamp(1.5rem, 2vw + 0.8rem, 2.2rem);
        font-weight: 800;
        line-height: 1.15;
        color: #f1f1ff;
        letter-spacing: -0.02em;
      }

      .hero-excerpt {
        font-size: 0.92rem;
        line-height: 1.6;
        color: #a9b1d6;
      }

      .hero-cta {
        margin-top: 0.5rem;
        font-size: 0.88rem;
        font-weight: 600;
        color: #7aa2f7;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      .cta-arrow {
        display: inline-block;
        transition: transform 0.25s ease;
      }

      .hero-feature-inner:hover .cta-arrow {
        transform: translateX(5px);
      }

      /* ─── Three-Column Quick Reads ─── */
      .quick-reads {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        margin-bottom: 3rem;
        border-top: 1px solid rgba(86, 95, 137, 0.3);
        border-bottom: 1px solid rgba(86, 95, 137, 0.3);
      }

      .quick-card {
        padding: 1.5rem;
        border-right: 1px solid rgba(86, 95, 137, 0.25);
        transition:
          background-color 0.3s ease,
          transform 0.3s ease;
      }

      .quick-card:last-child {
        border-right: none;
      }

      .quick-card:hover {
        background-color: rgba(36, 40, 59, 0.5);
        transform: translateY(-3px);
      }

      .quick-card-image {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%;
        border-radius: 10px;
        overflow: hidden;
        background: rgba(36, 40, 59, 0.7);
        margin-bottom: 1rem;
      }

      .quick-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .quick-card:hover .quick-img {
        transform: scale(1.05);
      }

      .quick-fallback {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(36, 40, 59, 0.9), rgba(187, 154, 247, 0.2));
      }

      .quick-card-body {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .quick-date {
        font-size: 0.73rem;
        color: #565f89;
        letter-spacing: 0.02em;
      }

      .quick-title {
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.3;
        color: #f1f1ff;
        transition: color 0.2s ease;
      }

      .quick-card:hover .quick-title {
        color: #7aa2f7;
      }

      .quick-excerpt {
        font-size: 0.84rem;
        line-height: 1.55;
        color: #a9b1d6;
      }

      /* ─── More Stories — Magazine Spread ─── */
      .more-stories {
        margin-bottom: 2rem;
      }

      .more-header {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        margin-bottom: 2rem;
      }

      .more-heading {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #565f89;
        white-space: nowrap;
      }

      .more-heading-line {
        flex: 1;
        height: 2px;
        background: linear-gradient(90deg, #7aa2f7, #bb9af7 50%, transparent);
        border-radius: 2px;
        opacity: 0.4;
      }

      /* ── Spotlight Card (first post — hero treatment) ── */
      .spotlight {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-radius: 18px;
        border: 1px solid rgba(86, 95, 137, 0.3);
        background: rgba(36, 40, 59, 0.55);
        overflow: hidden;
        margin-bottom: 1.6rem;
        transition:
          border-color 0.35s ease,
          box-shadow 0.35s ease,
          transform 0.35s ease;
      }

      .spotlight:hover {
        border-color: rgba(122, 162, 247, 0.55);
        box-shadow: 0 20px 50px rgba(10, 12, 22, 0.45);
        transform: translateY(-3px);
      }

      .spotlight-image {
        position: relative;
        overflow: hidden;
        min-height: 280px;
      }

      .spotlight-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .spotlight:hover .spotlight-img {
        transform: scale(1.04);
      }

      .spotlight-fallback {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(36, 40, 59, 0.9), rgba(122, 162, 247, 0.2));
      }

      .spotlight-number {
        position: absolute;
        top: 1rem;
        left: 1rem;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.5);
        background: rgba(26, 27, 38, 0.7);
        backdrop-filter: blur(8px);
        padding: 0.25rem 0.55rem;
        border-radius: 6px;
        border: 1px solid rgba(86, 95, 137, 0.3);
        font-variant-numeric: tabular-nums;
      }

      .spotlight-body {
        padding: 2rem 2.2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.65rem;
      }

      .spotlight-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.76rem;
      }

      .spotlight-tag {
        padding: 0.15rem 0.6rem;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(122, 162, 247, 0.15), rgba(187, 154, 247, 0.15));
        border: 1px solid rgba(122, 162, 247, 0.3);
        color: #7aa2f7;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 0.03em;
        text-transform: capitalize;
      }

      .spotlight-date {
        color: #565f89;
      }

      .spotlight-title {
        font-size: clamp(1.3rem, 1.8vw + 0.6rem, 1.8rem);
        font-weight: 800;
        line-height: 1.2;
        color: #f1f1ff;
        letter-spacing: -0.015em;
        transition: color 0.25s ease;
      }

      .spotlight:hover .spotlight-title {
        color: #7aa2f7;
      }

      .spotlight-excerpt {
        font-size: 0.9rem;
        line-height: 1.6;
        color: #a9b1d6;
      }

      .spotlight-cta {
        margin-top: 0.3rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: #7aa2f7;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
      }

      .spotlight:hover .cta-arrow {
        transform: translateX(5px);
      }

      /* ── Visual Grid Cards ── */
      .story-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.2rem;
      }

      .story-card {
        border-radius: 16px;
        border: 1px solid rgba(86, 95, 137, 0.25);
        background: rgba(36, 40, 59, 0.5);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
          border-color 0.3s ease,
          box-shadow 0.3s ease,
          transform 0.3s ease;
      }

      .story-card:hover {
        border-color: rgba(122, 162, 247, 0.5);
        box-shadow: 0 14px 35px rgba(10, 12, 22, 0.4);
        transform: translateY(-4px);
      }

      .story-card-visual {
        position: relative;
        width: 100%;
        padding-bottom: 60%;
        overflow: hidden;
        background: rgba(36, 40, 59, 0.7);
      }

      .story-card-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .story-card:hover .story-card-img {
        transform: scale(1.06);
      }

      .story-card-fallback {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(36, 40, 59, 0.9), rgba(187, 154, 247, 0.15));
      }

      .story-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(26, 27, 38, 0.7) 0%,
          rgba(26, 27, 38, 0.15) 45%,
          transparent 70%
        );
        pointer-events: none;
      }

      .story-card-number {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        font-size: 0.65rem;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.45);
        background: rgba(26, 27, 38, 0.65);
        backdrop-filter: blur(8px);
        padding: 0.2rem 0.45rem;
        border-radius: 5px;
        border: 1px solid rgba(86, 95, 137, 0.25);
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.05em;
      }

      .story-card-badge {
        position: absolute;
        bottom: 0.75rem;
        left: 0.75rem;
        font-size: 0.62rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        text-transform: capitalize;
        color: #c0caf5;
        background: rgba(26, 27, 38, 0.7);
        backdrop-filter: blur(8px);
        padding: 0.18rem 0.55rem;
        border-radius: 999px;
        border: 1px solid rgba(86, 95, 137, 0.3);
      }

      .story-card-content {
        padding: 1.1rem 1.3rem 1.3rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        flex: 1;
      }

      .story-card-date {
        font-size: 0.7rem;
        color: #565f89;
      }

      .story-card-title {
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.3;
        color: #f1f1ff;
        letter-spacing: -0.01em;
        transition: color 0.25s ease;
      }

      .story-card:hover .story-card-title {
        color: #7aa2f7;
      }

      .story-card-excerpt {
        font-size: 0.82rem;
        line-height: 1.55;
        color: #a9b1d6;
      }

      .story-card-read {
        margin-top: auto;
        padding-top: 0.5rem;
        font-size: 0.78rem;
        font-weight: 600;
        color: #7aa2f7;
        opacity: 0;
        transform: translateY(4px);
        transition:
          opacity 0.3s ease,
          transform 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      .story-card:hover .story-card-read {
        opacity: 1;
        transform: translateY(0);
      }

      .story-card:hover .story-card-read .cta-arrow {
        transform: translateX(4px);
      }

      /* ─── Pagination ─── */
      .pagination {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(86, 95, 137, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.25rem;
      }

      .pagination-link {
        padding: 0.5rem 1.2rem;
        border-radius: 999px;
        border: 1px solid rgba(86, 95, 137, 0.35);
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition:
          border-color 0.25s ease,
          color 0.25s ease,
          background-color 0.25s ease;
      }

      .pagination-active {
        color: #7aa2f7;
      }

      .pagination-active:hover {
        border-color: rgba(122, 162, 247, 0.6);
        color: #bb9af7;
        background-color: rgba(122, 162, 247, 0.08);
      }

      .pagination-disabled {
        color: rgba(86, 95, 137, 0.4);
        cursor: not-allowed;
        pointer-events: none;
      }

      .pagination-indicator {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.82rem;
        font-variant-numeric: tabular-nums;
      }

      .pagination-current {
        color: #f1f1ff;
        font-weight: 600;
      }

      .pagination-sep {
        color: rgba(86, 95, 137, 0.5);
      }

      .pagination-total {
        color: #565f89;
      }

      /* ─── Empty State ─── */
      .empty-state {
        margin-top: 3rem;
        padding: 2rem;
        border-radius: 14px;
        border: 1px dashed rgba(86, 95, 137, 0.4);
        text-align: center;
        color: #a9b1d6;
        font-size: 0.95rem;
      }

      /* ─── Utilities ─── */
      .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* ─── Animations ─── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(14px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .fade-up {
        animation: fadeUp 0.55s ease both;
      }

      .delay-1 {
        animation-delay: 0.08s;
      }

      .delay-2 {
        animation-delay: 0.16s;
      }

      .delay-3 {
        animation-delay: 0.24s;
      }

      .delay-4 {
        animation-delay: 0.32s;
      }

      .delay-5 {
        animation-delay: 0.40s;
      }

      .delay-6 {
        animation-delay: 0.48s;
      }

      /* ─── Responsive ─── */
      @media (max-width: 768px) {
        .masthead {
          flex-direction: column;
          gap: 0.5rem;
        }

        .masthead-links {
          margin-left: 0;
        }

        .hero-feature-inner {
          grid-template-columns: 1fr;
        }

        .hero-image-side {
          min-height: 220px;
          max-height: 260px;
        }

        .hero-accent-line {
          width: 100%;
          height: 3px;
          background: linear-gradient(90deg, #7aa2f7, #bb9af7);
        }

        .hero-text-side {
          padding: 1.4rem 1.5rem 1.6rem;
        }

        .hero-title {
          font-size: 1.4rem;
        }

        .quick-reads {
          grid-template-columns: 1fr;
          gap: 0;
        }

        .quick-card {
          border-right: none;
          border-bottom: 1px solid rgba(86, 95, 137, 0.25);
          padding: 1.2rem 0.5rem;
        }

        .quick-card:last-child {
          border-bottom: none;
        }

        .spotlight {
          grid-template-columns: 1fr;
        }

        .spotlight-image {
          min-height: 200px;
          max-height: 240px;
        }

        .spotlight-title {
          font-size: 1.25rem;
        }

        .spotlight-body {
          padding: 1.2rem 1rem 1.4rem;
        }

        .spotlight-number {
          font-size: 3rem;
          top: auto;
          left: auto;
          bottom: -0.5rem;
          right: 0.75rem;
        }

        .story-grid {
          grid-template-columns: 1fr;
          gap: 1rem;
        }

        .story-card-visual {
          padding-bottom: 0;
          height: 180px;
        }

        .story-card-content {
          padding: 0.9rem 1rem 1.1rem;
        }

        .story-card-read {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .fade-up {
          animation: none;
          opacity: 1;
        }

        .hero-feature-inner,
        .quick-card,
        .spotlight,
        .story-card,
        .pagination-link,
        .masthead-link,
        .cta-arrow,
        .spotlight-cta,
        .story-card-read {
          transition: none !important;
        }

        .hero-img,
        .quick-img,
        .spotlight-img,
        .story-card-img {
          transition: none !important;
        }

        .story-card-read {
          opacity: 1;
          transform: none;
        }
      }
    </style>

    <script is:inline>
      document.addEventListener("astro:page-load", () => {
        const imgs = document.querySelectorAll(
          ".hero-img, .quick-img, .spotlight-img, .story-card-img"
        );
        imgs.forEach((img) => {
          if (img.complete && img.naturalWidth > 0) {
            img.classList.add("loaded");
          } else {
            img.addEventListener("load", () => img.classList.add("loaded"), { once: true });
            img.addEventListener("error", () => img.classList.add("loaded"), { once: true });
          }
        });
      });
    </script>
  </body>
</html>
