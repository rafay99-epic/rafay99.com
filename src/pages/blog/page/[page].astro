---
import { type CollectionEntry, getCollection } from "astro:content";
import BaseHead from "@astro/base/BaseHead.astro";
import FeedCard from "@astro/blog/FeedCard.astro";
import Footer from "@astro/footer/Footer.astro";
import Header from "@astro/header/Header.astro";
import { featureFlags } from "@config/featureFlag/featureFlag.json";
import authorConfig from "@config/siteConfig/info.json";

export const prerender = true;

const postsPerPage = 9;

export async function getStaticPaths() {
	const perPage = 9;
	const allPosts = (await getCollection("blog"))
		.filter(
			(post: CollectionEntry<"blog">) =>
				!post.data.draft && !post.data.archived,
		)
		.sort(
			(a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
				b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
		);
	const totalPages = Math.ceil(allPosts.length / perPage);
	if (totalPages < 2) return [];
	return Array.from({ length: totalPages - 1 }, (_, i) => ({
		params: { page: String(i + 2) },
	}));
}

const { page } = Astro.params;
const currentPage = page ? parseInt(page, 10) : 1;

if (Number.isNaN(currentPage) || currentPage < 1) {
	return Astro.redirect("/blog");
}

const allPosts = (await getCollection("blog"))
	.filter(
		(post: CollectionEntry<"blog">) => !post.data.draft && !post.data.archived,
	)
	.sort(
		(a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);

if (currentPage > totalPages && totalPages > 0) {
	return Astro.redirect("/blog");
}

const startIndex = (currentPage - 1) * postsPerPage;
const endIndex = startIndex + postsPerPage;
const posts: CollectionEntry<"blog">[] = allPosts.slice(startIndex, endIndex);

const tagCounts = new Map();
for (const post of allPosts) {
	for (const tag of post.data.tags || []) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}

const showTags = featureFlags.showTags;
const showSearch = featureFlags.showSearch;

try {
	if (!featureFlags.showBlog) {
		return Astro.redirect("/access-denied");
	}
} catch (_error) {
	return Astro.redirect("/404");
}
---

<html lang="en">
  <head>
    <BaseHead
      title={`Articles - Page ${currentPage} | ${authorConfig.SiteName}`}
      description={`Browse articles on page ${currentPage} of ${authorConfig.SiteName}.`}
    />

    <style>
      html { background-color: #1a1b26; }
      body { background-color: #1a1b26; }
    </style>

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Blog",
        name: `${authorConfig.SiteName} Blog - Page ${currentPage}`,
        description: `Browse articles on page ${currentPage} of ${authorConfig.SiteName}.`,
        url: `https://rafay99.com/blog/page/${currentPage}`,
        publisher: {
          "@type": "Organization",
          name: authorConfig.SiteName,
          logo: {
            "@type": "ImageObject",
            url: "https://rafay99.com/favicon.webp",
          },
        },
        blogPost: posts.map(
          (post: CollectionEntry<"blog">, _index: number) => ({
            "@type": "BlogPosting",
            headline: post.data.title,
            description: post.data.description,
            author: {
              "@type": "Person",
              name: post.data.authorName,
            },
            datePublished: post.data.pubDate.toISOString(),
            url: `https://rafay99.com/blog/${post.id}`,
            keywords: post.data.tags?.join(", ") || "blog, technology",
          }),
        ),
      })}
    />
  </head>
  <body class="flex min-h-screen flex-col bg-[#1a1b26] text-[#a9b1d6]">
    <Header />

    <main class="page-shell mx-auto w-full max-w-6xl flex-1 px-5 pb-24 pt-14 sm:px-6">

      <header class="page-hero fade-up">
        <h1 class="page-title">Articles</h1>
        <div class="page-meta-bar">
          <span class="page-stat">Page {currentPage} of {totalPages}</span>
          <span class="page-dot">&middot;</span>
          <span class="page-stat">{totalPosts} total articles</span>
          <span class="page-dot">&middot;</span>
          <span class="page-stat">{tagCounts.size} topics</span>
          <span class="page-dot page-dot--actions">&middot;</span>
          <div class="page-actions">
            <a href="/blog" class="page-link">Latest</a>
            <a href="/blog/archive" class="page-link">Archive</a>
            {featureFlags.showSeries && <a href="/blog/series" class="page-link">Series</a>}
            {showSearch && <a href="/search" class="page-link">Search</a>}
            {showTags && <a href="/tag" class="page-link">Tags</a>}
          </div>
        </div>
      </header>

      {posts.length === 0 && (
        <div class="empty-state">
          <p>No articles on this page.</p>
        </div>
      )}

      {posts.length > 0 && (
        <section class="feed-list">
          {posts.map((post, index) => (
            <FeedCard post={post} index={index} showSeries={featureFlags.showSeries} />
          ))}
        </section>
      )}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination">
          <a
            href={currentPage > 1 ? (currentPage === 2 ? "/blog" : `/blog/page/${currentPage - 1}`) : "#"}
            class:list={[
              "pagination-link",
              currentPage > 1 ? "pagination-active" : "pagination-disabled",
            ]}
          >
            <span>&larr; Previous</span>
          </a>
          <div class="pagination-pill">
            {currentPage} / {totalPages}
          </div>
          <a
            href={currentPage < totalPages ? `/blog/page/${currentPage + 1}` : "#"}
            class:list={[
              "pagination-link",
              currentPage < totalPages ? "pagination-active" : "pagination-disabled",
            ]}
          >
            <span>Next &rarr;</span>
          </a>
        </nav>
      )}
    </main>

    <Footer />

    <style>
      .page-shell {
        position: relative;
        isolation: isolate;
      }

      .page-hero {
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(86, 95, 137, 0.25);
        margin-bottom: 1.5rem;
      }

      .page-title {
        font-size: clamp(1.8rem, 2.5vw + 0.8rem, 2.6rem);
        font-weight: 700;
        line-height: 1.1;
        color: #f8f8ff;
        letter-spacing: -0.02em;
      }

      .page-meta-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.75rem;
        font-size: 0.85rem;
      }

      .page-stat { color: #565f89; }
      .page-dot { color: rgba(86, 95, 137, 0.5); }

      .page-actions {
        display: flex;
        gap: 0.75rem;
      }

      .page-link {
        color: #7aa2f7;
        font-weight: 500;
        transition: color 0.2s ease;
      }

      .page-link:hover { color: #bb9af7; }

      .feed-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .pagination {
        margin-top: 2.5rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(86, 95, 137, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
      }

      .pagination-link {
        padding: 0.45rem 1.1rem;
        border-radius: 999px;
        border: 1px solid rgba(86, 95, 137, 0.35);
        font-size: 0.85rem;
        font-weight: 500;
        transition: border-color 0.25s ease, color 0.25s ease;
      }

      .pagination-active { color: #7aa2f7; }

      .pagination-active:hover {
        border-color: rgba(122, 162, 247, 0.6);
        color: #bb9af7;
      }

      .pagination-disabled {
        color: rgba(86, 95, 137, 0.5);
        cursor: not-allowed;
      }

      .pagination-pill {
        font-size: 0.8rem;
        color: #565f89;
        font-variant-numeric: tabular-nums;
      }

      .empty-state {
        margin-top: 2.5rem;
        padding: 1.5rem;
        border-radius: 16px;
        border: 1px dashed rgba(86, 95, 137, 0.4);
        text-align: center;
        color: #a9b1d6;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .fade-up { animation: fadeUp 0.6s ease both; }

      @media (max-width: 640px) {
        .feed-list { gap: 0.75rem; }

        .page-dot--actions { display: none; }

        .page-actions {
          width: 100%;
          margin-top: 0.25rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .fade-up { animation: none; }
        .pagination-link { transition: none; }
      }
    </style>
  </body>
</html>
