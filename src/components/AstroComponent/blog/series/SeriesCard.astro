---
/**
 * SeriesCard — visual card used on the /blog/series listing page.
 *
 * Shows the series name, number of parts, latest date, hero image,
 * and tags.
 */

import { Image } from "astro:assets";
import type { SeriesMeta } from "types/series";

interface Props {
	meta: SeriesMeta;
	index: number;
}

const { meta, index } = Astro.props;

const formattedDate = meta.latestDate.toLocaleDateString("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
});
---

<a
	href={`/blog/series/${meta.slug}`}
	class:list={["series-card group", `fade-up delay-${Math.min(index + 1, 4)}`]}
>
	<div class="series-card-image">
		{meta.heroImage ? (
			<Image
				src={meta.heroImage}
				alt={meta.title}
				width={400}
				height={225}
				loading={index < 3 ? "eager" : "lazy"}
				decoding="async"
				class="series-card-img"
			/>
		) : (
			<div class="series-card-fallback" aria-hidden="true">
				<svg
					width="32"
					height="32"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
				</svg>
			</div>
		)}
		<div class="series-card-overlay" aria-hidden="true">
			<span class="series-card-count">
				{meta.postCount} {meta.postCount === 1 ? "Part" : "Parts"}
			</span>
		</div>
	</div>

	<div class="series-card-body">
		<h3 class="series-card-title">{meta.title}</h3>
		{meta.description && (
			<p class="series-card-desc">{meta.description}</p>
		)}
		<div class="series-card-footer">
			<span class="series-card-date">{formattedDate}</span>
			{meta.tags.length > 0 && (
				<div class="series-card-tags">
					{meta.tags.slice(0, 3).map((tag) => (
						<span class="series-card-tag">#{tag}</span>
					))}
				</div>
			)}
		</div>
	</div>
</a>

<style>
	.series-card {
		display: flex;
		flex-direction: column;
		border-radius: 16px;
		border: 1px solid rgba(86, 95, 137, 0.18);
		background: rgba(36, 40, 59, 0.4);
		overflow: hidden;
		text-decoration: none;
		transition:
			border-color 0.25s ease,
			transform 0.25s ease,
			box-shadow 0.25s ease;
	}

	.series-card:hover {
		border-color: rgba(187, 154, 247, 0.35);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
	}

	/* ─── Image ─── */
	.series-card-image {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: rgba(36, 40, 59, 0.6);
		background-image: linear-gradient(
			90deg,
			rgba(36, 40, 59, 0.7) 0%,
			rgba(65, 72, 104, 0.3) 50%,
			rgba(36, 40, 59, 0.7) 100%
		);
		background-size: 200% 100%;
		animation: shimmer 1.8s ease-in-out infinite;
	}

	@keyframes shimmer {
		0% { background-position: 200% 0; }
		100% { background-position: -200% 0; }
	}

	.series-card-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0;
		transition: opacity 0.4s ease, transform 0.35s ease;
	}

	.series-card-img.loaded {
		opacity: 1;
	}

	.series-card:hover .series-card-img {
		transform: scale(1.05);
	}

	.series-card-fallback {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, rgba(36, 40, 59, 0.9), rgba(187, 154, 247, 0.15));
		color: #565f89;
	}

	.series-card-overlay {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
	}

	.series-card-count {
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		background: rgba(26, 27, 38, 0.8);
		backdrop-filter: blur(4px);
		font-size: 0.7rem;
		font-weight: 600;
		color: #bb9af7;
		border: 1px solid rgba(187, 154, 247, 0.25);
	}

	/* ─── Body ─── */
	.series-card-body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1rem 1.15rem 1.15rem;
		flex: 1;
	}

	.series-card-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: #c0caf5;
		line-height: 1.3;
		transition: color 0.2s ease;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.series-card:hover .series-card-title {
		color: #bb9af7;
	}

	.series-card-desc {
		font-size: 0.85rem;
		color: #a9b1d6;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.series-card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}

	.series-card-date {
		font-size: 0.72rem;
		color: #565f89;
		white-space: nowrap;
	}

	.series-card-tags {
		display: flex;
		gap: 0.35rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.series-card-tag {
		font-size: 0.68rem;
		color: #7aa2f7;
		opacity: 0.7;
	}

	/* ─── Animations ─── */
	@keyframes fadeUp {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.fade-up {
		animation: fadeUp 0.6s ease both;
	}

	.delay-1 { animation-delay: 0.08s; }
	.delay-2 { animation-delay: 0.16s; }
	.delay-3 { animation-delay: 0.24s; }
	.delay-4 { animation-delay: 0.32s; }

	@media (prefers-reduced-motion: reduce) {
		.fade-up {
			animation: none;
		}
		.series-card,
		.series-card-img {
			transition: none;
		}
	}
</style>

<script is:inline>
	document.addEventListener("astro:page-load", () => {
		const imgs = document.querySelectorAll(".series-card-img");
		imgs.forEach((img) => {
			if (img.complete && img.naturalWidth > 0) {
				img.classList.add("loaded");
			} else {
				img.addEventListener("load", () => img.classList.add("loaded"), { once: true });
				img.addEventListener("error", () => img.classList.add("loaded"), { once: true });
			}
		});
	});
</script>
